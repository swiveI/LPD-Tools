---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.tsx";
import HowToVcc from "../components/HowToVcc.astro";
import SearchBar from "../components/SearchBar.astro";
import PackageGrid from "../components/PackageGrid.tsx";
import DarkVeil from "../component/DarkVeil.jsx";
import source from "../../../source.json";
import listing from "../data/listing.json";

// Resolve packages from the Nuke-generated listing.json
// Each package ID maps to { versions: { "x.y.z": manifest } }
interface PackageManifest {
  name: string;
  displayName?: string;
  description?: string;
  version: string;
  author?: { name?: string; url?: string };
  url?: string;
  license?: string;
  licensesUrl?: string;
  keywords?: string[];
  vpmDependencies?: Record<string, string>;
}

type ListingPackages = Record<
  string,
  { versions: Record<string, PackageManifest> }
>;

const rawPackages = (listing as { packages: ListingPackages }).packages ?? {};

function semverCompare(a: string, b: string): number {
  const pa = a.split(".").map(Number);
  const pb = b.split(".").map(Number);
  for (let i = 0; i < 3; i++) {
    if ((pa[i] ?? 0) !== (pb[i] ?? 0)) return (pb[i] ?? 0) - (pa[i] ?? 0);
  }
  return 0;
}

// Safely process packages with error handling for malformed data
function processPackage(
  id: string,
  pkg: { versions: Record<string, PackageManifest> }
): {
  id: string;
  displayName: string;
  description: string;
  version: string;
  type: string;
  authorName?: string;
  authorUrl?: string;
  zipUrl?: string;
  license?: string;
  licensesUrl?: string;
  keywords: string[];
  dependencies: { name: string; version: string }[];
} | null {
  try {
    // Validate package structure
    if (!pkg || typeof pkg !== "object" || !pkg.versions) {
      console.warn(`Invalid package structure for ${id}`);
      return null;
    }

    const versionKeys = Object.keys(pkg.versions);
    if (versionKeys.length === 0) {
      console.warn(`No versions found for package ${id}`);
      return null;
    }

    const versions = versionKeys.sort(semverCompare);
    const latest = pkg.versions[versions[0]];
    if (!latest) {
      console.warn(`Could not resolve latest version for ${id}`);
      return null;
    }

    // Validate required fields
    if (!latest.version) {
      console.warn(`Missing version in latest release for ${id}`);
      return null;
    }

    // Safely extract dependencies
    const deps: { name: string; version: string }[] = [];
    if (latest.vpmDependencies && typeof latest.vpmDependencies === "object") {
      for (const [name, version] of Object.entries(latest.vpmDependencies)) {
        if (typeof version === "string") {
          deps.push({ name, version });
        }
      }
    }

    // Determine package type
    let type = "Any";
    if (deps.some((d) => d.name.includes("avatars"))) type = "Avatar";
    else if (deps.some((d) => d.name.includes("worlds"))) type = "World";

    return {
      id,
      displayName: latest.displayName?.trim() || id,
      description: latest.description?.trim() || "",
      version: latest.version,
      type,
      authorName: latest.author?.name?.trim(),
      authorUrl: latest.author?.url?.trim(),
      zipUrl: latest.url?.trim(),
      license: latest.license?.trim(),
      licensesUrl: latest.licensesUrl?.trim(),
      keywords: Array.isArray(latest.keywords) ? latest.keywords.filter((k): k is string => typeof k === "string") : [],
      dependencies: deps,
    };
  } catch (error) {
    console.error(`Error processing package ${id}:`, error);
    return null;
  }
}

const packages = Object.entries(rawPackages)
  .map(([id, pkg]) => processPackage(id, pkg))
  .filter((pkg): pkg is NonNullable<ReturnType<typeof processPackage>> => pkg !== null);

const bannerUrl = source.bannerUrl
  ? `/${source.bannerUrl}`
  : null;

const socialLinks = [
  {
    key: "github",
    label: "GitHub",
    href: source.socials?.github,
  },
  {
    key: "website",
    label: "Website",
    href: source.socials?.website,
  },
  {
    key: "twitter",
    label: "Twitter",
    href: source.socials?.twitter,
  },
].filter((item) => typeof item.href === "string" && item.href.trim().length > 0);
---

<Layout title={source.name} description={source.description}>
  <div class="relative min-h-screen">
    <!-- Clean navy blue background -->
    <div class="fixed inset-0 -z-10 bg-[#080a1c]"></div>

    <main class="max-w-6xl mx-auto py-12 px-4 relative z-10">
      <Hero
        client:load
        name={source.name}
        description={source.description}
        listingUrl={source.url}
        author={source.author}
        socials={socialLinks}
        bannerUrl={bannerUrl ?? undefined}
      />

      <HowToVcc />

      {packages.length > 0 && <SearchBar />}

      <PackageGrid client:load packages={packages} listingUrl={source.url} />

    <footer class="text-center mt-12 pb-8">
      <p class="text-xs text-[var(--color-border)]">
        Powered by <a
          href="https://vcc.docs.vrchat.com"
          target="_blank"
          rel="noopener"
          class="text-[var(--color-border)] hover:text-[var(--color-orchid)] transition-colors"
          >VPM</a
        >
      </p>
    </footer>
  </main>
  </div>
</Layout>
